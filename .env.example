# ── VaultGuard — Variáveis de ambiente (Docker Compose) ───────────────────
# Copie para .env e ajuste os valores OBRIGATÓRIOS antes de subir.
# Uso rápido: ./install.sh (gera tudo automaticamente)

# ── Porta de acesso ──────────────────────────────────────────────────────────
# Mude para 8080 se a porta 80 já estiver em uso no servidor
HTTP_PORT=80
HTTPS_PORT=443

# ── Banco de dados ───────────────────────────────────────────────────────────
# OBRIGATÓRIO: troque por uma senha forte
DB_PASSWORD=troque-esta-senha-do-banco

# ── JWT Secret ───────────────────────────────────────────────────────────────
# OBRIGATÓRIO: string aleatória longa — gere com:
#   openssl rand -hex 64
JWT_SECRET=troque-por-string-aleatoria-minimo-64-caracteres-use-openssl-rand-hex-64

# ── URL pública do sistema ───────────────────────────────────────────────────
# Coloque o IP ou domínio pelo qual o sistema será acessado.
# Exemplos:
#   FRONTEND_URL=http://192.168.1.100
#   FRONTEND_URL=http://192.168.1.100:8080
#   FRONTEND_URL=https://vault.empresa.com
FRONTEND_URL=http://SEU_IP_OU_DOMINIO

# ── Administrador inicial (usado pelo seed na primeira execução) ──────────────
# Atenção: após a primeira subida, mudar estas vars não altera o usuário existente.
COMPANY_NAME=MinhaEmpresa
ADMIN_EMAIL=admin@minhaempresa.com
ADMIN_PASSWORD=TrocaEsta@123

# ── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production
