# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://vaultguard:SENHA_AQUI@localhost:5432/vaultguard"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET="troque-por-uma-string-aleatoria-de-64-chars-minimo"

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost

# ─── Active Directory (configurado pela UI de Admin) ───────────────────────────
# A configuração do LDAP é feita pela interface web em Admin > Active Directory
# e armazenada no banco de dados. As variáveis abaixo são opcionais para override.
# LDAP_HOST=192.168.0.10
# LDAP_PORT=389
# LDAP_BASE_DN=DC=empresa,DC=local
# LDAP_BIND_DN=CN=vaultguard-svc,OU=ServiceAccounts,DC=empresa,DC=local
# LDAP_BIND_PASSWORD=senha_da_service_account
